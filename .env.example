# ===========================
# LOGGRO API CREDENTIALS
# ===========================
LOGGRO_EMAIL=tu_email@ejemplo.com
LOGGRO_PASSWORD=tu_password_aqui

# ===========================
# DJANGO SETTINGS
# ===========================
SECRET_KEY=tu_secret_key_django_aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================
# DATABASE (si usas PostgreSQL)
# ===========================
# DB_NAME=nombre_base_datos
# DB_USER=usuario
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432

# ===========================
# CORS SETTINGS
# ===========================
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===========================
# NOTAS
# ===========================
# 1. Copia este archivo a .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. NUNCA subas el archivo .env a GitHub
